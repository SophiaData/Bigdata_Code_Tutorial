<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Puppy Crawl//DTD Suppressions 1.1//EN"
        "http://www.puppycrawl.com/dtds/suppressions_1_1.dtd">

<suppressions>
    <!-- target 目录不检查 -->
    <suppress files="[\\/]target[\\/]" checks=".*"/>

    <!-- .mimocode 目录不检查 -->
    <suppress files="[\\/]\\.mimocode[\\/]" checks=".*"/>

    <!-- 正在开发的 e2e 测试模块，后续逐步修复 -->
    <suppress files="e2e-tests[\\/]" checks="RegexpHeader"/>

    <!-- docs 目录不检查 -->
    <suppress files="[\\/]docs[\\/]" checks=".*"/>
</suppressions>
