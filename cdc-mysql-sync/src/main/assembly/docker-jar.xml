<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0 http://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>docker</id>
    <formats>
        <format>jar</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <dependencySets>
        <dependencySet>
            <outputDirectory>/</outputDirectory>
            <useProjectArtifact>false</useProjectArtifact>
            <unpack>true</unpack>
            <scope>provided</scope>
            <excludes>
                <exclude>org.apache.flink:flink-shaded-*</exclude>
                <exclude>org.apache.flink:flink-dist-*</exclude>
                <exclude>org.apache.flink:flink-streaming-java</exclude>
                <exclude>org.apache.flink:flink-java</exclude>
                <exclude>org.apache.flink:flink-table-api-java-bridge</exclude>
                <exclude>org.apache.flink:flink-table-planner_*</exclude>
                <exclude>org.apache.flink:flink-table-common</exclude>
                <exclude>org.apache.flink:flink-table-runtime</exclude>
                <exclude>org.apache.flink:flink-table-api-java</exclude>
                <exclude>org.apache.flink:flink-table-api-bridge-base</exclude>
                <exclude>org.apache.flink:flink-connector-base</exclude>
                <exclude>org.apache.flink:flink-runtime-web</exclude>
                <exclude>org.apache.flink:flink-clients</exclude>
                <exclude>org.apache.flink:flink-core</exclude>
                <exclude>org.apache.flink:flink-runtime</exclude>
                <exclude>org.apache.flink:flink-optimizer</exclude>
                <exclude>org.apache.flink:flink-annotations</exclude>
                <exclude>org.apache.flink:flink-metrics-core</exclude>
                <exclude>org.apache.flink:flink-shaded-force-shading</exclude>
                <exclude>org.slf4j:*</exclude>
                <exclude>org.apache.logging.log4j:*</exclude>
                <exclude>ch.qos.reload4j:*</exclude>
                <exclude>org.apache.hadoop:*</exclude>
                <exclude>com.alibaba.nacos:*</exclude>
            </excludes>
        </dependencySet>
        <dependencySet>
            <outputDirectory>/</outputDirectory>
            <useProjectArtifact>false</useProjectArtifact>
            <unpack>true</unpack>
            <scope>runtime</scope>
            <excludes>
                <exclude>org.apache.flink:flink-shaded-*</exclude>
                <exclude>org.apache.flink:flink-dist-*</exclude>
            </excludes>
        </dependencySet>
        <dependencySet>
            <outputDirectory>/</outputDirectory>
            <useProjectArtifact>true</useProjectArtifact>
            <unpack>true</unpack>
        </dependencySet>
    </dependencySets>
</assembly>
