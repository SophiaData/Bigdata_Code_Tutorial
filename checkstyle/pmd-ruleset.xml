<?xml version="1.0"?>
<ruleset name="Custom PMD Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">
    <description>Custom PMD rules for Bigdata_Code_Tutorial - Critical issues only</description>

    <!-- Use basic ruleset and exclude most rules -->
    <rule ref="rulesets/java/quickstart.xml">
        <!-- Exclude all rules except the most critical ones -->
        <exclude name="CloseResource"/>
        <exclude name="EmptyCatchBlock"/>
        <exclude name="EmptyFinallyBlock"/>
        <exclude name="EmptyTryBlock"/>
        <exclude name="EmptyWhileStmt"/>
        <exclude name="UnusedPrivateField"/>
        <exclude name="UnusedPrivateMethod"/>
        <exclude name="UnusedLocalVariable"/>
        <exclude name="UnusedFormalParameter"/>
        <exclude name="UnusedAssignment"/>
        <exclude name="UnusedImports"/>
        <exclude name="UnnecessaryImport"/>
        <exclude name="AtLeastOneConstructor"/>
        <exclude name="ClassNamingConventions"/>
        <exclude name="FieldNamingConventions"/>
        <exclude name="FormalParameterNamingConventions"/>
        <exclude name="LocalVariableNamingConventions"/>
        <exclude name="MethodNamingConventions"/>
        <exclude name="ShortClassName"/>
        <exclude name="ShortVariable"/>
        <exclude name="TooManyStaticImports"/>
        <exclude name="MethodArgumentCouldBeFinal"/>
        <exclude name="LocalVariableCouldBeFinal"/>
        <exclude name="OnlyOneReturn"/>
        <exclude name="UnnecessaryLocalBeforeReturn"/>
        <exclude name="FieldDeclarationsShouldBeAtStartOfClass"/>
        <exclude name="CommentDefaultAccessModifier"/>
        <exclude name="UseDiamondOperator"/>
        <exclude name="SignatureDeclareThrowsException"/>
        <exclude name="LawOfDemeter"/>
        <exclude name="SingularField"/>
        <exclude name="CyclomaticComplexity"/>
        <exclude name="CognitiveComplexity"/>
        <exclude name="ExcessiveImports"/>
        <exclude name="ExcessiveMethodLength"/>
        <exclude name="ExcessivePublicCount"/>
        <exclude name="ExcessiveParameterList"/>
        <exclude name="LoosePackageCoupling"/>
        <exclude name="AddEmptyString"/>
        <exclude name="LinguisticNaming"/>
        <exclude name="AvoidArrayLoops"/>
        <exclude name="AvoidInstantiatingObjectsInLoops"/>
        <exclude name="AvoidStringBufferField"/>
        <exclude name="ConsecutiveLiteralAppends"/>
        <exclude name="ConsecutiveStringConcatenation"/>
        <exclude name="OptimizableToArrayCall"/>
        <exclude name="UselessStringValueBuffer"/>
        <exclude name="AvoidUsingVolatile"/>
        <exclude name="DoNotUseThreads"/>
        <exclude name="SynchronizedMethod"/>
        <exclude name="SynchronizedStatement"/>
        <exclude name="LiteralsFirstInComparisons"/>
        <exclude name="UseUtilityClass"/>
        <exclude name="PreserveStackTrace"/>
        <exclude name="GuardLogStatement"/>
        <exclude name="UnusedNullCheckInEquals"/>
        <exclude name="UselessParentheses"/>
        <exclude name="UseLocaleWithCaseConversions"/>
        <exclude name="ImplicitSwitchFallThrough"/>
        <exclude name="ReturnEmptyCollectionRatherThanNull"/>
        <exclude name="UnnecessaryFullyQualifiedName"/>
        <exclude name="AvoidUsingHardCodedIP"/>
        <exclude name="AvoidUsingHardCoded passwords"/>
        <exclude name="DoNotCallGarbageCollectionExplicitly"/>
        <exclude name="DoNotCallSystemExit"/>
        <exclude name="DoNotCallThreadRun"/>
        <exclude name="DoNotUseThreads"/>
        <exclude name="MoreThanOneLogger"/>
        <exclude name="MissingSerialVersionUID"/>
        <exclude name="ConstructorCallsOverridableMethod"/>
        <exclude name="FieldNamingConventions"/>
        <exclude name="FormalParameterNamingConventions"/>
        <exclude name="LocalVariableNamingConventions"/>
        <exclude name="MethodNamingConventions"/>
        <exclude name="ShortClassName"/>
        <exclude name="ShortVariable"/>
        <exclude name="TooManyStaticImports"/>
        <exclude name="ClassNamingConventions"/>
        <exclude name="AtLeastOneConstructor"/>
        <exclude name="MethodArgumentCouldBeFinal"/>
        <exclude name="LocalVariableCouldBeFinal"/>
        <exclude name="OnlyOneReturn"/>
        <exclude name="UnnecessaryLocalBeforeReturn"/>
        <exclude name="FieldDeclarationsShouldBeAtStartOfClass"/>
        <exclude name="CommentDefaultAccessModifier"/>
        <exclude name="UseDiamondOperator"/>
        <exclude name="CyclomaticComplexity"/>
        <exclude name="CognitiveComplexity"/>
        <exclude name="ExcessiveImports"/>
        <exclude name="ExcessiveMethodLength"/>
        <exclude name="ExcessivePublicCount"/>
        <exclude name="ExcessiveParameterList"/>
        <exclude name="LoosePackageCoupling"/>
        <exclude name="SingularField"/>
        <exclude name="SignatureDeclareThrowsException"/>
        <exclude name="LawOfDemeter"/>
    </rule>
</ruleset>
